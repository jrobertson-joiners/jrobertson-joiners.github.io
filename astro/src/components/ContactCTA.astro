---
import { SITE, whatsappHref } from '../data/site';
import PhoneIcon from './icons/PhoneIcon.astro';
import WhatsAppIcon from './icons/WhatsAppIcon.astro';

const baseClasses = "inline-flex items-center justify-center gap-2 rounded-full px-6 py-3 font-semibold shadow-lg transition";
---

<div class="rounded-2xl bg-[var(--primary-dark)] text-white p-8 shadow-lg">
  <p class="text-sm font-semibold text-orange-200 mb-4">Ready to get started?</p>
  <h3 class="text-2xl font-bold mb-4">Let's discuss your project</h3>
  <p class="text-white/80 mb-6">
    Whether you're planning a kitchen refresh, loft conversion, or full contract build, we're here to help. Get in touch for a friendly chat and a free, no-obligation quote.
  </p>
  <div class="flex flex-wrap gap-4">
    <a href="/contact/" class={`${baseClasses} bg-white text-[var(--primary-dark)] hover:bg-slate-100`}>
      Get a Free Quote
    </a>
    <a href={`tel:${SITE.phoneTel}`} class={`${baseClasses} border border-white/30 text-white hover:bg-white/10`}>
      <PhoneIcon />
      {SITE.phone}
    </a>
    <a href={whatsappHref} target="_blank" rel="noreferrer noopener" class={`${baseClasses} border border-white/30 text-white hover:bg-white/10`}>
      <WhatsAppIcon />
      WhatsApp
    </a>
  </div>
</div>
