---
import { Image } from 'astro:assets';
import logoImage from '../assets/images/logo.png';
import { MENU_LINKS, SITE } from '../data/site';
import PhoneIcon from './icons/PhoneIcon.astro';

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  href === '/' ? currentPath === '/' : currentPath.startsWith(href);
---

<header class="sticky top-0 z-50 bg-white/95 backdrop-blur shadow-sm border-b border-slate-100">
  <div class="max-w-6xl mx-auto flex items-center justify-between px-4 py-3">
    <a href="/" class="text-lg md:text-xl font-semibold text-slate-900 flex items-center gap-2">
      <Image
        src={logoImage}
        alt="Jamie Robertson Joiners"
        width={320}
        quality={90}
        format="webp"
        layout="none"
        class="h-10 w-auto"
        loading="eager"
      />
      <span>Jamie Robertson <span class="text-[var(--accent-wood)]">Joiners<span class="hidden md:inline"> &amp;
            Building Contractor</span></span></span>
    </a>

    <!-- Desktop Nav -->
    <nav class="hidden md:flex items-center gap-6 text-sm font-medium" aria-label="Main navigation">
      {MENU_LINKS.map(link => (
        <a
          href={link.href}
          aria-current={isActive(link.href) ? 'page' : undefined}
          class:list={['hover:text-[var(--accent-wood)]', isActive(link.href) && 'text-[var(--accent-wood)] font-semibold']}
        >{link.label}</a>
      ))}
    </nav>

    <div class="flex items-center gap-2 md:gap-4">
      <!-- Desktop click-to-call -->
      <a href={`tel:${SITE.phoneTel}`}
        class="hidden md:inline-flex items-center gap-2 text-sm font-semibold text-slate-700 hover:text-[var(--accent-wood)]">
        <PhoneIcon />
        {SITE.phone}
      </a>
      <a href="/contact/"
        class="hidden md:inline-flex items-center rounded-full bg-[var(--accent-wood)] px-6 py-3 font-semibold text-white shadow-lg transition hover:bg-orange-700">
        Get in Touch
      </a>
      <!-- Mobile click-to-call -->
      <a href={`tel:${SITE.phoneTel}`} class="md:hidden inline-flex h-11 w-11 items-center justify-center text-[var(--primary-dark)]" aria-label={`Call us on ${SITE.phone}`}>
        <PhoneIcon class="h-6 w-6" />
      </a>
      <!-- Mobile Menu Button -->
      <button id="mobile-menu-btn" class="md:hidden inline-flex h-11 w-11 items-center justify-center text-slate-600 hover:text-[var(--accent-wood)]"
        aria-label="Toggle menu" aria-expanded="false" aria-controls="mobile-menu">
        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" focusable="false">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
        </svg>
      </button>
    </div>
  </div>

  <!-- Mobile Menu Dropdown -->
  <div id="mobile-menu" class="hidden md:hidden border-t border-slate-100 bg-white px-4 py-2 shadow-lg">
    <nav class="flex flex-col text-sm font-medium" aria-label="Mobile navigation">
      {MENU_LINKS.map(link => (
        <a
          href={link.href}
          aria-current={isActive(link.href) ? 'page' : undefined}
          class:list={['block py-3 hover:text-[var(--accent-wood)]', isActive(link.href) && 'text-[var(--accent-wood)] font-semibold']}
        >{link.label}</a>
      ))}
      <a href="/contact/"
        class="mt-2 mb-2 block w-full text-center rounded-full bg-[var(--accent-wood)] px-6 py-3 font-semibold text-white shadow-lg transition hover:bg-orange-700">Get in Touch</a>
    </nav>
  </div>
</header>

<script>
  const btn = document.getElementById('mobile-menu-btn');
  const menu = document.getElementById('mobile-menu');
  const links = menu?.querySelectorAll('a');

  const closeMenu = () => {
    menu?.classList.add('hidden');
    btn?.setAttribute('aria-expanded', 'false');
  };

  btn?.addEventListener('click', () => {
    const isHidden = menu?.classList.toggle('hidden');
    btn.setAttribute('aria-expanded', String(!isHidden));
  });

  // Close menu when a link is clicked
  links?.forEach(link => {
    link.addEventListener('click', closeMenu);
  });

  // Close on Escape and return focus to the toggle
  document.addEventListener('keydown', (event) => {
    if (event.key === 'Escape' && !menu?.classList.contains('hidden')) {
      closeMenu();
      btn?.focus();
    }
  });
</script>
