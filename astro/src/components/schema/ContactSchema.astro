---
import { SITE, ORG_ID, absUrl } from '../../data/site';

const schema = {
  "@context": "https://schema.org",
  "@type": "ContactPage",
  "@id": absUrl("/contact/"),
  "name": `Contact ${SITE.title}`,
  "description": "Get in touch with Jamie Robertson Joiners for a free quote on joinery, kitchens, loft conversions, and building work in Stirling.",
  "mainEntity": {
    "@id": ORG_ID
  },
  "potentialAction": {
    "@type": "CommunicateAction",
    "target": [
      {
        "@type": "EntryPoint",
        "urlTemplate": `tel:${SITE.phoneTel}`,
        "name": "Call us"
      },
      {
        "@type": "EntryPoint",
        "urlTemplate": `mailto:${SITE.email}`,
        "name": "Email us"
      },
      {
        "@type": "EntryPoint",
        "urlTemplate": SITE.whatsappUrl,
        "name": "WhatsApp us"
      }
    ]
  }
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
