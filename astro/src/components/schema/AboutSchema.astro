---
import { SITE, ORG_ID, absUrl } from '../../data/site';

const schema = {
  "@context": "https://schema.org",
  "@type": "AboutPage",
  "@id": absUrl("/about/"),
  "name": `About ${SITE.title}`,
  "description": "Learn about Jamie Robertson Joiners - joinery-led building contractors serving Stirling and Central Scotland since 2016.",
  "mainEntity": {
    "@id": ORG_ID
  }
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
