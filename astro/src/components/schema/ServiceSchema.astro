---
import { SITE, ORG_ID, absUrl } from '../../data/site';

interface Props {
  name: string;
  description: string;
  url: string;
  image?: string;
  serviceType: string;
  areaServed?: string[];
}

const { name, description, url, image, serviceType, areaServed = ['Stirling', 'Central Scotland'] } = Astro.props;

const schema = {
  "@context": "https://schema.org",
  "@type": "Service",
  "@id": url,
  "name": name,
  "description": description,
  "serviceType": serviceType,
  "provider": {
    "@id": ORG_ID
  },
  "areaServed": areaServed.map(area => ({
    "@type": "City",
    "name": area
  })),
  "availableChannel": {
    "@type": "ServiceChannel",
    "serviceUrl": absUrl("/contact/"),
    "servicePhone": SITE.phoneTel
  },
  ...(image && { "image": image })
};
---

<script is:inline type="application/ld+json" set:html={JSON.stringify(schema)} />
