---
/**
 * Sticky Mobile CTA - Floating call/WhatsApp button on mobile devices
 * Only shows on scroll after hero section
 */
import { SITE, whatsappHref } from '../data/site';
import PhoneIcon from './icons/PhoneIcon.astro';
import WhatsAppIcon from './icons/WhatsAppIcon.astro';
---

<!-- Sticky Mobile CTA - only visible on mobile -->
<div id="sticky-cta" class="fixed left-4 right-4 z-40 md:hidden translate-y-24 opacity-0 transition-all duration-300" style="bottom: calc(1rem + env(safe-area-inset-bottom));">
  <div class="flex gap-2">
    <a
      href={`tel:${SITE.phoneTel}`}
      class="flex-1 inline-flex items-center justify-center gap-2 rounded-full bg-[var(--primary-dark)] px-6 py-3 font-semibold text-white shadow-lg transition hover:bg-blue-800"
      aria-label={`Call us on ${SITE.phone}`}
    >
      <PhoneIcon />
      Call Now
    </a>
    <a
      href={whatsappHref}
      target="_blank"
      rel="noreferrer noopener"
      class="flex-1 inline-flex items-center justify-center gap-2 rounded-full bg-[var(--accent-wood)] px-6 py-3 font-semibold text-white shadow-lg transition hover:bg-orange-700"
      aria-label="Message us on WhatsApp"
    >
      <WhatsAppIcon />
      WhatsApp
    </a>
  </div>
</div>

<script>
  // Show/hide sticky CTA based on scroll position
  const stickyCta = document.getElementById('sticky-cta');
  const footer = document.querySelector('footer');
  const showThreshold = 400; // Show after scrolling 400px
  
  function updateCtaVisibility() {
    const scrollY = window.scrollY;
    const windowHeight = window.innerHeight;
    const footerTop = footer?.getBoundingClientRect().top ?? Infinity;
    
    // Hide if not scrolled enough OR if footer is visible
    if (scrollY <= showThreshold || footerTop < windowHeight) {
      stickyCta?.classList.add('translate-y-24', 'opacity-0');
      stickyCta?.classList.remove('translate-y-0', 'opacity-100');
    } else {
      stickyCta?.classList.remove('translate-y-24', 'opacity-0');
      stickyCta?.classList.add('translate-y-0', 'opacity-100');
    }
  }
  
  // Throttle scroll events for performance
  let ticking = false;
  window.addEventListener('scroll', () => {
    if (!ticking) {
      window.requestAnimationFrame(() => {
        updateCtaVisibility();
        ticking = false;
      });
      ticking = true;
    }
  }, { passive: true });
  
  // Initial check
  updateCtaVisibility();
</script>
