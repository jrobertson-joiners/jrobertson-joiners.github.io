---
/**
 * Phone (handset) glyph. Decorative by default (aria-hidden) — pair with an
 * accessible label on the surrounding link/button. Pass `class` to size it.
 */
interface Props {
  class?: string;
}

const { class: className = 'h-5 w-5' } = Astro.props;
---

<svg xmlns="http://www.w3.org/2000/svg" class={className} fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
  <path stroke-linecap="round" stroke-linejoin="round" d="M3 5h2l2 5-2 1c1 4 4 7 8 8l1-2 5 2v2c0 1-1 2-2 2a16 16 0 01-16-16c0-1 1-2 2-2z" />
</svg>
