---
import type { ServiceFaq } from '../data/serviceFaqs';

/**
 * Visible FAQ accordion (native <details>). Render the surrounding section and
 * heading in the page; pair with <FAQSchema> for the structured-data twin.
 */
interface Props {
  faqs: ServiceFaq[];
}

const { faqs } = Astro.props;
---

<div class="space-y-4">
  {faqs.map(faq => (
    <details class="group bg-white rounded-xl shadow-md border border-slate-100">
      <summary class="flex cursor-pointer items-center justify-between p-5 text-left font-semibold text-slate-900 hover:bg-slate-50 rounded-xl">
        <span>{faq.question}</span>
        <svg class="h-5 w-5 shrink-0 text-slate-500 transition-transform group-open:rotate-180" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true" focusable="false">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 9l-7 7-7-7" />
        </svg>
      </summary>
      <div class="px-5 pb-5 text-slate-600">
        {faq.answer}
      </div>
    </details>
  ))}
</div>
