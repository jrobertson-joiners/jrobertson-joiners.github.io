---
import Base from '../layouts/Base.astro';
import OrganizationSchema from '../components/schema/OrganizationSchema.astro';
import ContactSchema from '../components/schema/ContactSchema.astro';
import BreadcrumbSchema from '../components/schema/BreadcrumbSchema.astro';
import { SITE, whatsappHref } from '../data/site';
import PhoneIcon from '../components/icons/PhoneIcon.astro';
import WhatsAppIcon from '../components/icons/WhatsAppIcon.astro';

const fieldClasses =
  "mt-2 w-full rounded-xl border border-slate-200 px-4 py-3 focus:border-[var(--accent-wood)] focus:outline-none focus:ring-2 focus:ring-[var(--accent-wood)]";
---

<Base
  title="Contact Us | Jamie Robertson Joiners | Stirling"
  description="Get in touch with Jamie Robertson Joiners for a free quote on joinery, kitchens, loft conversions, and building work in Stirling and Central Scotland."
  canonicalPath="/contact/"
>
  <Fragment slot="head">
    <OrganizationSchema />
    <ContactSchema />
    <BreadcrumbSchema items={[
      { name: 'Home', path: '/' },
      { name: 'Contact Us', path: '/contact/' }
    ]} />
  </Fragment>
  <!-- Hero Section -->
  <section class="bg-[var(--primary-dark)] text-white py-16">
    <div class="max-w-6xl mx-auto px-4">
      <p class="text-sm font-semibold text-orange-200 mb-2">Get in touch</p>
      <h1 class="text-4xl md:text-5xl font-bold mb-4">Contact Us</h1>
      <p class="text-lg text-white/80 max-w-2xl">
        Ready to discuss your project? We'd love to hear from you — we typically reply within one working day.
      </p>
    </div>
  </section>

  <!-- Contact Section -->
  <section class="py-16">
    <div class="max-w-6xl mx-auto px-4 grid gap-8 lg:grid-cols-2">
      <!-- Contact Info -->
      <div class="rounded-2xl bg-[var(--primary-dark)] text-white p-8 shadow-lg">
        <p class="text-sm font-semibold text-orange-200 mb-4">Contact Details</p>
        <ul class="space-y-6">
          <li class="flex items-start gap-4">
            <span class="mt-1 text-[var(--accent-wood)]">
              <PhoneIcon class="h-6 w-6" />
            </span>
            <div>
              <p class="text-xs uppercase tracking-wide text-white/70">Phone</p>
              <p class="text-lg font-semibold">
                <a href={`tel:${SITE.phoneTel}`} class="hover:text-[var(--accent-wood)] transition-colors">{SITE.phone}</a>
              </p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="mt-1 text-[var(--accent-wood)]">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24"
                stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                <path stroke-linecap="round" stroke-linejoin="round" d="M3 8l9 6 9-6" />
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M5 6h14a2 2 0 012 2v8a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2z" />
              </svg>
            </span>
            <div>
              <p class="text-xs uppercase tracking-wide text-white/70">Email</p>
              <p class="text-lg font-semibold">
                <a href={`mailto:${SITE.email}`}
                  class="hover:text-[var(--accent-wood)] transition-colors">{SITE.email}</a>
              </p>
            </div>
          </li>
          <li class="flex items-start gap-4">
            <span class="mt-1 text-[var(--accent-wood)]">
              <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24"
                stroke="currentColor" stroke-width="2" aria-hidden="true" focusable="false">
                <path stroke-linecap="round" stroke-linejoin="round"
                  d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z" />
                <path stroke-linecap="round" stroke-linejoin="round" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z" />
              </svg>
            </span>
            <div>
              <p class="text-xs uppercase tracking-wide text-white/70">Service Area</p>
              <p class="text-lg font-semibold">Stirling & Central Scotland</p>
            </div>
          </li>
        </ul>

        <div class="mt-8 pt-6 border-t border-white/20">
          <p class="text-sm text-white/70 mb-4">Prefer to message?</p>
          <a href={whatsappHref}
            class="w-full inline-flex items-center justify-center gap-2 rounded-full bg-white px-6 py-3 font-semibold text-[var(--primary-dark)] shadow-lg hover:bg-slate-100"
            target="_blank" rel="noreferrer noopener">
            <WhatsAppIcon class="h-5 w-5 text-green-600" />
            Message on WhatsApp
          </a>
        </div>

        <div class="mt-6">
          <a href={SITE.social.facebook}
            class="w-full inline-flex items-center justify-center gap-2 rounded-full border border-white/30 px-6 py-3 font-semibold text-white hover:bg-white/10"
            target="_blank" rel="noreferrer noopener">
            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" focusable="false">
              <path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/>
            </svg>
            Follow on Facebook
          </a>
        </div>
      </div>

      <!-- Contact Form -->
      <div class="rounded-2xl bg-white p-8 shadow-lg border border-slate-200">
        <h2 class="text-2xl font-semibold text-slate-900 mb-2">
          Send a quick message
        </h2>
        <p class="text-sm text-slate-600 mb-6">
          Tell us a little about your project and we'll get back to you within one working day with a free, no-obligation quote.
        </p>
        <form id="contact-form" action={SITE.formspreeUrl} method="POST" class="space-y-5">
          <input type="hidden" name="_subject" value="New enquiry from website" />
          <!-- Honeypot: hidden from real users; bots that fill it are dropped by Formspree -->
          <input type="text" name="_gotcha" tabindex="-1" autocomplete="off" aria-hidden="true" style="display:none !important" />
          <div>
            <label for="name" class="block text-sm font-medium text-slate-700">Name</label>
            <input type="text" id="name" name="name" autocomplete="name"
              class={fieldClasses}
              placeholder="Your full name" required />
          </div>
          <div>
            <label for="email" class="block text-sm font-medium text-slate-700">Email</label>
            <input type="email" id="email" name="email" autocomplete="email"
              class={fieldClasses}
              placeholder="name@email.com" required />
          </div>
          <div>
            <div class="flex items-center justify-between">
              <label for="phone" class="block text-sm font-medium text-slate-700">Phone</label>
              <span class="text-xs text-slate-500">Optional</span>
            </div>
            <input type="tel" id="phone" name="phone" autocomplete="tel"
              class={fieldClasses}
              placeholder={`e.g. ${SITE.phone}`} />
          </div>
          <div class="grid gap-5 sm:grid-cols-2">
            <div>
              <div class="flex items-center justify-between">
                <label for="service" class="block text-sm font-medium text-slate-700">What can we help with?</label>
                <span class="text-xs text-slate-500">Optional</span>
              </div>
              <select id="service" name="service" class={fieldClasses}>
                <option value="">Please select…</option>
                <option>Kitchen installation</option>
                <option>Loft conversion</option>
                <option>Home extension</option>
                <option>General joinery</option>
                <option>Full contract build</option>
                <option>Something else</option>
              </select>
            </div>
            <div>
              <div class="flex items-center justify-between">
                <label for="town" class="block text-sm font-medium text-slate-700">Your town / area</label>
                <span class="text-xs text-slate-500">Optional</span>
              </div>
              <input type="text" id="town" name="town" autocomplete="address-level2"
                class={fieldClasses}
                placeholder="e.g. Dunblane" />
            </div>
          </div>
          <div>
            <label for="message" class="block text-sm font-medium text-slate-700">Message</label>
            <textarea id="message" name="message" rows="4"
              class={fieldClasses}
              placeholder="Tell us about your project" required></textarea>
          </div>
          <button type="submit"
            class="w-full rounded-full bg-[var(--accent-wood)] px-6 py-3 font-semibold text-white shadow-lg transition hover:bg-orange-700 focus:outline-none focus:ring-2 focus:ring-[var(--accent-wood)] focus:ring-offset-2">
            Send Message
          </button>
          <div id="form-status" class="hidden text-center text-sm" tabindex="-1" aria-live="polite"></div>
          <p class="text-xs text-slate-500 mt-3">
            By submitting this form, you agree that we may store and use your details to respond to your enquiry, as set
            out in our <a href="/privacy/" class="underline hover:text-[var(--accent-wood)]">Privacy Policy</a>. We will
            not share your information with third parties.
          </p>
        </form>
      </div>
    </div>
  </section>

  <Fragment slot="scripts">
    <script>
      const form = document.getElementById("contact-form") as HTMLFormElement;
      const status = document.getElementById("form-status") as HTMLElement;

      function setStatus(message: string, tone: 'pending' | 'success' | 'error') {
        const toneClass =
          tone === 'success' ? 'text-green-700 font-medium'
          : tone === 'error' ? 'text-red-700 font-medium'
          : 'text-slate-600';
        status.className = `mt-4 text-center text-sm ${toneClass}`;
        status.setAttribute('role', tone === 'error' ? 'alert' : 'status');
        // Match aria-live to the tone — the static 'polite' would otherwise
        // override role="alert"'s implicit assertiveness for errors.
        status.setAttribute('aria-live', tone === 'error' ? 'assertive' : 'polite');
        status.textContent = message;
        if (tone !== 'pending') status.focus();
      }

      async function handleSubmit(event: Event) {
        event.preventDefault();
        const data = new FormData(form);

        setStatus('Sending…', 'pending');

        try {
          const response = await fetch(form.action, {
            method: form.method,
            body: data,
            headers: {
              'Accept': 'application/json'
            }
          });

          if (response.ok) {
            setStatus(
              "Thank you for your message! We'll be in touch within one working day. For a faster reply, call or WhatsApp us anytime.",
              'success'
            );
            form.reset();
          } else {
            const result = await response.json();
            if (Object.hasOwn(result, 'errors')) {
              setStatus(result.errors.map((error: {message: string}) => error.message).join(", "), 'error');
            } else {
              setStatus("Oops! There was a problem submitting your form. Please call or WhatsApp us instead.", 'error');
            }
          }
        } catch (error) {
          setStatus("Oops! There was a problem submitting your form. Please call or WhatsApp us instead.", 'error');
        }
      }

      form.addEventListener("submit", handleSubmit);
    </script>
  </Fragment>
</Base>
